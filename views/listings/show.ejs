<% layout('/layout/boilerplate') -%>

<script>
  const mapToken = <%- JSON.stringify(mapToken || "") %>;
  const listingGeometry = <%- JSON.stringify(listing.geometry || null) %>;
  const listingLocation = <%- JSON.stringify(`${listing.location}, ${listing.country}`) %>;
</script>
  <div class="row">
    <div class="col-8 offset-2">
      <div class="card listing-card">

        <h3 class="mt-3 text-center">
          <b>
            <%= listing.title %>
          </b>
        </h3>

        <img src="<%= listing.image.url %>" class="card-img-top show-img" alt="listing_image">

        <div class="card-body">

          <p class="card-text">
            <% if (listing.owner) { %>
              <i>Owned by <%= listing.owner.username %></i><br>
              <% } %>

                <%= listing.description %><br>
                  &#8377; <%= listing.price.toLocaleString("en-IN") %>/night<br>
                    <%= listing.location %><br>
                      <%= listing.country %>
          </p>

          <% if ( currUser && listing.owner && listing.owner._id.toString()===currUser._id.toString() ) { %>

            <div class="mt-3">
              <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark">
                Edit
              </a>

              <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" class="d-inline"
                onsubmit="return confirm('Are you sure?')">
                <button class="btn btn-danger" type="submit">
                  Delete
                </button>
              </form>
            </div>

            <% } %>

              <% if (currUser) { %>

                <div class="col-8 offset-2 mt-4">
                  <h4>Leave a Review</h4>

                  <form action="/listings/<%= listing._id %>/reviews" method="POST" novalidate class="needs-validation">

                    <div class="mb-3">
                      <label for="rating" class="form-label">Rating</label>

                      <input type="range" min="1" max="5" value="3" id="rating" name="review[rating]"
                        class="form-range">
                    </div>

                    <div class="mb-3">
                      <label for="comment" class="form-label">Comments</label>

                      <textarea name="review[comment]" id="comment" rows="5" class="form-control" required></textarea>

                      <div class="invalid-feedback">
                        Please add some comment for review
                      </div>
                    </div>

                    <button class="btn btn-danger" type="submit">
                      Submit
                    </button>

                  </form>
                </div>

                <% } %>

                  <hr>


                  <% if (listing.reviews.length===0) { %>
                    <h4 class="mb-4"><b>All Reviews</b></h4>

                    <p>No reviews yet.</p>

                    <% } else { %>

                      <div class="row">

                        <% for (let review of listing.reviews) { %>

                          <div class="col-md-6 mb-4">
                            <div class="card review-card h-100">

                              <div class="card-body">

                                <h5 class="card-title">
                                  <%= review.author && review.author.username ? review.author.username
                                    : "Anonymous User" %>
                                </h5>

                                <p class="card-text review-comment">
                                  <%= review.comment %>
                                </p>

                                <p class="card-text review-rating">
                                  Rating: <%= review.rating %>/5 ⭐
                                </p>

                                <% if ( currUser && review.author &&
                                  review.author._id.toString()===currUser._id.toString() ) { %>

                                  <form method="POST"
                                    action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                                    <button class="btn btn-sm btn-dark">
                                      Delete
                                    </button>
                                  </form>

                                  <% } %>

                              </div>

                            </div>
                          </div>

                          <% } %>

                      </div>

                      <% } %>



                        <div class="col-8 offset-2 mb-3">
                          <h3>Where you'll be</h3>
                          <div id="map"></div>
                        </div>

                        
        </div>
      </div>
    </div>
  </div>
  <script src="/JS/map.js"></script>
